{
  "name": "@syncra/api",
  "version": "0.1.0",
  "private": true,
  "description": "Syncra NestJS backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsc --watch && node dist/main.js",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "migrate": "tsx ../../infra/scripts/migrate.ts",
    "migrate:up": "tsx ../../infra/scripts/migrate.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@syncra/config": "workspace:*",
    "@syncra/core": "workspace:*",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/uuid": "^9.0.0",
    "bcrypt": "^5.0.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "ioredis": "^5.10.1",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^4.6.0",
    "tsx": "^4.7.0",
    "vitest": "^1.0.0"
  }
}
